{
  "homepage": "https://developerfolio.js.org/",
  "name": "developerfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "colorthief": "^2.3.0",
    "lottie-react": "^2.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-easy-emoji": "^1.8.1",
    "react-headroom": "^3.0.0",
    "react-twitter-embed": "3.0.3"
  },
  "scripts": {
    "preinstall": "npm config set legacy-peer-deps true",
    "predeploy": "npm run build",
    "dev": "node fetch.js && vite",
    "start": "npm run dev",
    "build": "node fetch.js && vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -b master -d dist",
    "format": "prettier --write \"./**/*.{js,css,json,scss}\"",
    "check-format": "prettier -c \"./**/*.{js,css,json,scss}\"",
    "vercel-build": "npm install --legacy-peer-deps && node fetch.js && vite build"
  },
  "browserslist": {
    "production": [
      ">0.3%",
      "not ie 11",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      ">0.3%",
      "not ie 11",
      "not dead",
      "not op_mini all",
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "dotenv": "^16.3.1",
    "gh-pages": "^6.0.0",
    "prettier": "^3.0.0",
    "sass": "^1.66.1",
    "vite": "^4.4.5"
  }
}
